# Smart contracts and blockchain
contracts
deployments
# ...but the relay-gateway image (services/relay-gateway/Dockerfile) bakes the deployment
# records for its FR-025 version-pinned target check. Re-include them (last match wins; harmless
# to the SPA build, which doesn't COPY them).
!deployments
artifacts
cache
typechain-types

# Scripts
scripts

# CI/CD
.circleci
.travis.yml
.gitlab-ci.yml

# IDE
.vscode
.idea
*.swp
*.swo
*~

# Environment files — never copy secrets into the build image. The **/ patterns match
# any depth (e.g. frontend/.env) so a local `docker build .` cannot sweep a real
# VITE_PINATA_* / VITE_RPC_URL secret into the context where Vite would inline it.
.env
.env.local
.env.*.local
**/.env
**/.env.*

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Temp files
tmp
temp
*.tmp

# Hardhat specific
hardhat.config.js
slither*.txt
slither.config.json
medusa.json
remappings.txt
.solcover.js

# MkDocs
mkdocs.yml
requirements.txt

# Blockscout
blockscout

# Package lock files (not needed in image)
# Note: frontend/package-lock.json is kept for reproducible builds
yarn.lock
pnpm-lock.yaml
