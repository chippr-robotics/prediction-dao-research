# FairWins ZK-Wager Pool gas relayer — environment template.
# Copy to `.env` and fill in. NEVER commit `.env` (it holds the gas key). `.env*` is gitignored.
#
# ─────────────────────────────────────────────────────────────────────────────
# Gas-only signer
# ─────────────────────────────────────────────────────────────────────────────
# The relayer's funded key. It pays gas to submit members' pre-signed EIP-3009 joins.
# THREAT MODEL: this key can CENSOR (refuse/drop a join) but can NEVER STEAL — the member's
# authorization is bound to (from, pool, value, nonce) and is replay-protected by the ERC-3009 token.
# Fund it with just enough native gas token per chain; rotate by swapping the key and topping up.
# Do NOT reuse the floppy-keystore admin key here; this is a hot, low-value, gas-only key.
RELAYER_PRIVATE_KEY=

# Comma-separated chainIds this relayer serves. Each needs RPC_URL_<id> + POOL_FACTORY_<id>
# (+ SANCTIONS_GUARD_<id> when REQUIRE_SANCTIONS_SCREEN=true).
# 137 = Polygon mainnet, 80002 = Polygon Amoy, 63 = Mordor (ETC testnet).
ENABLED_CHAIN_IDS=80002

# ─────────────────────────────────────────────────────────────────────────────
# Per-chain RPC + contract addresses
# (these are the SAME addresses the frontend resolves via getContractAddressForChain;
#  paste the deployed zkWagerPoolFactory + sanctionsGuard for each chain)
# ─────────────────────────────────────────────────────────────────────────────
# --- Polygon Amoy (80002) ---
RPC_URL_80002=https://rpc-amoy.polygon.technology
POOL_FACTORY_80002=0xYourZkWagerPoolFactoryOnAmoy
SANCTIONS_GUARD_80002=0xdF41355dD5E47FCA4eE2F2205af4C70Dab8C13B3

# --- Polygon mainnet (137) — uncomment + fill when serving mainnet ---
# RPC_URL_137=https://polygon-bor-rpc.publicnode.com
# POOL_FACTORY_137=0xYourZkWagerPoolFactoryOnPolygon
# SANCTIONS_GUARD_137=0x2Dc53d91A189be71DfE96Ea9BCFCF6aDDA77BC76

# ─────────────────────────────────────────────────────────────────────────────
# Screening (FR-021d): fail closed when screening can't be performed
# ─────────────────────────────────────────────────────────────────────────────
# true (default): require a SanctionsGuard per chain and refuse to relay if its isAllowed() call fails
# or the wallet is screened out. Only set false for non-value-bearing local/dev chains.
REQUIRE_SANCTIONS_SCREEN=true

# ─────────────────────────────────────────────────────────────────────────────
# Server + rate limiting
# ─────────────────────────────────────────────────────────────────────────────
PORT=8787
# Per-IP rate limit on /relay/pool-join.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20
# Confirmations to await before returning txHash. 0 returns on broadcast (fastest); >0 waits for
# inclusion (more reliable for the caller, slower).
TX_CONFIRMATIONS=0
