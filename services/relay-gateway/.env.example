# FairWins relay gateway — local/dev environment. NEVER commit a filled-in .env.
# In production these come from Secret Manager / Cloud Run env (see README).

# Chains served (default: the chains with deployments/ records). 61 (ETC mainnet) has no
# deployment record yet — enabling it fails the FR-025 startup check by design.
ENABLED_CHAIN_IDS=137,80002,63

# >=2 endpoints per chain, comma-separated, failover order (FR-007). Defaults are public pairs.
#RPC_URLS_137=https://polygon-rpc.com,https://polygon-bor-rpc.publicnode.com
#RPC_URLS_80002=https://rpc-amoy.polygon.technology,https://polygon-amoy-bor-rpc.publicnode.com
#RPC_URLS_63=https://rpc.mordor.etccooperative.org,https://geth-mordor.etc-network.info

# Origin lock (FR-029): same secret the Cloudflare Transform Rule injects as X-Origin-Auth.
# UNSET => lock disabled (dev only; production MUST set it).
ORIGIN_AUTH_SECRET=

# Engine (OpenZeppelin Relayer) — see ../oz-relayer/README.md
ENGINE_URL=http://localhost:8080
#ENGINE_API_KEY=
# Engine relayer ids default to <name>-<chainId>: polygon-137, amoy-80002, etc-61, mordor-63
#ENGINE_RELAYER_ID_137=polygon-137

# Shared secret the engine presents on POST /v1/engine/webhook (X-Webhook-Secret).
# UNSET => all webhooks rejected (fail closed).
WEBHOOK_SHARED_SECRET=

# Kill switch (FR-015): boot value; toggle at runtime with `kill -USR2 <pid>`.
KILL_SWITCH=false

# Quotas / caps (FR-009/FR-014/FR-018)
#SIGNER_QUOTA_PER_MIN=12
#GLOBAL_QUOTA_PER_MIN=120
#MAX_QUEUE_DEPTH=100
#GAS_SPEND_CAP_WEI_137=500000000000000000
#SPEND_WINDOW_MS=3600000

# healthz runway (observability only — the KEY never lives here)
#GAS_WALLET_137=0x...
#PEAK_BURN_WEI_PER_HR_137=50000000000000000

#PORT=8788

# --- Sponsored paymaster (spec 050) -----------------------------------------------------------
# Sponsorship is enabled ONLY on chains with a paymaster address set below, so leaving just
# PAYMASTER_ADDRESS_137 set scopes sponsorship to Polygon mainnet. Unset => /v1/paymaster refuses
# that chain and the SPA self-funds (never-stranded).
#PAYMASTER_ADDRESS_137=0x...              # deployed FairWinsVerifyingPaymaster (from deployments/polygon.json)
#ENTRYPOINT_V06_137=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789   # default; override only if needed
# Sponsorship signer: dev/CI uses a raw key (NEVER a production secret); prod uses Cloud KMS.
#PM_SIGNER_PRIVATE_KEY=0x...              # dev/test only
#PM_SIGNER_KMS_KEY=projects/.../cryptoKeyVersions/1   # prod (same custody class as the relayer gas key)
# Per-op ceilings + burst quotas (defense-in-depth; the deposit is the hard cap).
#PM_MAX_COST_WEI=2000000000000000000      # 2 MATIC / op worst-case cost ceiling
#PM_MAX_GAS=3000000                       # per-op gas-units ceiling (deploy+transfer < ~2M)
#PM_ACCOUNT_QUOTA_PER_MIN=6
#PM_GLOBAL_QUOTA_PER_MIN=60
#PM_APPROVAL_TTL_SEC=180                  # sponsorship approval validity window
#PM_RUNWAY_WARN_HRS=48                    # deposit runway warning threshold (observability)

# --- OpenSea proxy (spec 055 read + spec 056 sell-side) -----------------------------------------
# UNSET key => /v1/opensea/* fails closed (503 collectibles_unconfigured) and the SPA hides the
# Collect tab; nothing else is affected. In prod the key comes from Secret Manager.
#OPENSEA_API_KEY=
#OPENSEA_BASE_URL=https://api.opensea.io
#OPENSEA_TIMEOUT_MS=5000
#OPENSEA_RETRIES=1
#OPENSEA_CACHE_TTL_MS=60000               # account list / item detail / fee cache
#OPENSEA_STATS_CACHE_TTL_MS=300000        # collection floor stats cache (floors move slowly)
#OPENSEA_QUOTA_PER_ADDRESS=60             # reads/min per requested address|contract|slug
#OPENSEA_QUOTA_GLOBAL=300                 # reads/min backstop for the shared key
# Sell-side writes (spec 056): a separate, tighter quota keyed by the seller's account address.
#OPENSEA_WRITE_QUOTA_PER_ADDRESS=20       # listings/cancels/accepts per minute per seller
#OPENSEA_WRITE_QUOTA_GLOBAL=100           # writes/min backstop for the shared key
# FairWins referral/affiliate beneficiary of OpenSea's OWN reward (public address; never a surcharge).
# UNSET => attribution disabled (safe default). Per-chain override wins over the global.
#OPENSEA_REFERRAL_ADDRESS=0x...
#OPENSEA_REFERRAL_ADDRESS_137=0x...

# --- Polymarket / Predict proxy (spec 057) -----------------------------------------------------
# UNSET key => /v1/polymarket/* fails closed (503 predict_unconfigured) and the SPA hides the
# Predict tab; nothing else is affected. Polygon-only (Polymarket runs only on 137). In prod the
# key + L2 secret/passphrase come from Secret Manager (the L2 creds are derived once offline via
# L1, so the gateway holds no order-signing key).
#POLYMARKET_API_KEY=
#POLYMARKET_API_SECRET=                    # base64url L2 HMAC secret (from POST /auth/api-key)
#POLYMARKET_API_PASSPHRASE=
#POLYMARKET_API_ADDRESS=0x...              # the operator wallet the API creds belong to
#POLYMARKET_BASE_URL=https://clob.polymarket.com
# Polymarket splits across three public hosts: CLOB (orders/fees/auth), Gamma (market discovery +
# search), Data API (positions). Browse hits Gamma, positions hit Data — both public (no L2 creds).
#POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
#POLYMARKET_DATA_URL=https://data-api.polymarket.com
#POLYMARKET_TIMEOUT_MS=5000
#POLYMARKET_RETRIES=1
#POLYMARKET_CACHE_TTL_MS=15000             # market/fee read cache (prices move fast)
#POLYMARKET_QUOTA_PER_ADDRESS=60           # reads/min per requested address
#POLYMARKET_QUOTA_GLOBAL=300               # reads/min backstop for the shared key
#POLYMARKET_WRITE_QUOTA_PER_ADDRESS=20     # order/cancel per minute per trader
#POLYMARKET_WRITE_QUOTA_GLOBAL=100         # writes/min backstop for the shared key
# FairWins builder code (public bytes32). UNSET => orders post UNATTRIBUTED (never stranded), no fee.
# The builder fee is ADDITIVE on top of Polymarket's platform taker fee (a real user cost, disclosed
# honestly in the UI). Hard-capped at 100 bps taker / 50 bps maker — out-of-range fails boot.
#POLYMARKET_BUILDER_CODE=0x6e0316783960e149b53466f0f2c5fdbaf5ce11ba15669491de980f6dedc493a3
#POLYMARKET_BUILDER_TAKER_FEE_BPS=50       # 0.50% on taker orders (default)
#POLYMARKET_BUILDER_MAKER_FEE_BPS=0        # makers kept whole (default)
