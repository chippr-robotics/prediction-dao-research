# Frontend Environment Configuration
# Copy this file to .env for local development

# Network Configuration
# For local development (Hardhat): 1337
# For Polygon Amoy testnet: 80002
# For Polygon mainnet: 137
# For Mordor testnet (Ethereum Classic): 63
# For Ethereum Classic mainnet: 61
VITE_NETWORK_ID=137

# RPC URL for connecting to blockchain
# Local: http://localhost:8545
# Polygon Amoy: https://rpc-amoy.polygon.technology
# Polygon mainnet: https://polygon-bor-rpc.publicnode.com
# Mordor: https://rpc.mordor.etccooperative.org
# Ethereum Classic: https://etc.rivet.link
#
# NOTE: VITE_RPC_URL is a GLOBAL override applied to EVERY chain. Leave it unset to
# use the correct per-chain default for VITE_NETWORK_ID (recommended). Only set it to
# pin one RPC, and keep it consistent with the chain selected above (e.g. a Polygon
# URL when VITE_NETWORK_ID=137 — otherwise a 137 app would read from an Amoy RPC).
# VITE_RPC_URL=

# --- Indexing subgraph (Spec 017: v2 WagerRegistry + WagerTransfer) ---
# Subgraph endpoints are now resolved PER-CHAIN in src/config/networks.js, so a
# network without an indexer (e.g. Ethereum Classic Mordor) transparently reads
# wagers directly from the WagerRegistry over RPC (RegistrySource) — no global
# flag required. Defaults ship for the indexed networks; override per-chain only
# if you run your own indexer:
#   VITE_SUBGRAPH_URL_POLYGON  (137)   default: studio fairwins-polygon
#   VITE_SUBGRAPH_URL_AMOY     (80002) default: studio fairwins-amoy
#   VITE_SUBGRAPH_URL_MORDOR   (63)    default: none → RPC reads (no subgraph)
# (Studio dev query endpoints are rate-limited; for production publish to the
#  decentralized network and use the gateway URL.)
# VITE_SUBGRAPH_URL_POLYGON=
# VITE_SUBGRAPH_URL_AMOY=
# VITE_SUBGRAPH_URL_MORDOR=
#
# Legacy single-endpoint override. Applies ONLY to the build-time active chain
# (VITE_NETWORK_ID) and never leaks to other networks at runtime. Prefer the
# per-chain vars above.
# VITE_SUBGRAPH_URL=
# Force a specific wager data source for debugging: subgraph | registry | events.
# Leave unset to auto-select per chain (subgraph where indexed, RPC otherwise).
# VITE_WAGER_SOURCE=
#
# The Graph Studio DEPLOY KEY is a secret used only by `graph auth` when deploying
# the subgraph — it is NOT a frontend var and MUST live in your local .env only,
# never committed.

# --- Mordor (Ethereum Classic testnet, chainId 63) overrides (Spec 015) ---
# All optional; networks.js ships sensible defaults. Set these to point at a
# custom RPC, the verified Classic USD (USC) token, or ETCswap so the in-app
# swap turns on. The DEX/swap capability stays OFF (and the swap UI hidden)
# until ALL of FACTORY + SWAP_ROUTER + QUOTER + WETC are provided — no mock DEX.
# VITE_RPC_URL_MORDOR=https://rpc.mordor.etccooperative.org
# VITE_MORDOR_USC=0xDE093684c796204224BC081f937aa059D903c52a   # VERIFY on-chain (T001)
# VITE_MORDOR_ETCSWAP_FACTORY=
# VITE_MORDOR_ETCSWAP_SWAP_ROUTER=
# VITE_MORDOR_ETCSWAP_QUOTER=
# VITE_MORDOR_ETCSWAP_POSITION_MANAGER=
# VITE_MORDOR_WETC=
# VITE_MORDOR_FAUCET=                                          # test-ETC faucet (T003)
# VITE_MORDOR_ETCSWAP_URL=https://etcswap.org

# Contract Addresses (update after deployment)
# VITE_CONTRACT_ADDRESS=0x1234567890123456789012345678901234567890

# IPFS / Pinata Configuration
# Pinata is used for uploading and pinning content to IPFS
# Get your credentials at https://app.pinata.cloud/developers/api-keys

# Pinata JWT Token — SECURITY: SERVER-SIDE ONLY. Do NOT set this as a VITE_ var in any
# deployed/production build. Vite inlines every VITE_* value into the client bundle in
# cleartext, which would leak your Pinata write credential to every visitor. Production
# IPFS uploads go through the server-side /api/pinata proxy (frontend/nginx.conf.template),
# which injects the JWT at container runtime. The production build will FAIL if this is set
# (see the pinataSecretGuard in frontend/vite.config.js). Leave it commented for builds;
# uncomment only for a local `npm run dev` that talks to Pinata directly.
# VITE_PINATA_JWT=your_pinata_jwt_token_here

# Pinata API Key and Secret (alternative to JWT)
# VITE_PINATA_API_KEY=your_pinata_api_key
# VITE_PINATA_API_SECRET=your_pinata_api_secret

# Pinata Gateway URL (optional - for dedicated gateway)
# Default uses Pinata's public gateway
# VITE_PINATA_GATEWAY=https://your-gateway.mypinata.cloud

# IPFS Gateway URL for retrieving token and market data
# Default: Uses Pinata gateway
VITE_IPFS_GATEWAY=https://gateway.pinata.cloud

# ETC/USD Price Fallback (used if CoinGecko API fails)
# VITE_ETC_USD_FALLBACK=20

# WalletConnect Configuration (Optional)
# WalletConnect is always available with a fallback project ID
# For production deployments, get your own project ID from https://cloud.walletconnect.com
# VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# ThirdWeb Configuration (Optional)
# ThirdWeb provides enhanced wallet connection UX
# For production deployments, get your own client ID from https://thirdweb.com/dashboard
# VITE_THIRDWEB_CLIENT_ID=your_client_id_here

# Application URL (Required for production)
# Used for WalletConnect metadata and other external integrations
# For local development: http://localhost:5173
# For production: https://your-domain.com
VITE_APP_URL=http://localhost:5173

# Which oracle models the frontend exposes in the wager-creation flow + landing copy.
#   polymarket-only (default, also when unset) — show ONLY Polymarket; hide
#       Chainlink Data Feed / Chainlink Functions / UMA from the user UI.
#   all — restore every oracle model (the contracts always support them).
# Contracts/adapters are unchanged; this is a UI-visibility switch.
# VITE_ORACLE_MODELS=polymarket-only
