# Frontend Environment Configuration
# Copy this file to .env for local development

# Network Configuration
# The app targets Polygon Amoy — Polymarket's testnet — by default.
# For Polygon Amoy: 80002
# For local development (Hardhat): 1337
VITE_NETWORK_ID=80002

# RPC URL for connecting to blockchain
# Polygon Amoy: https://rpc-amoy.polygon.technology
# Local: http://localhost:8545
VITE_RPC_URL=https://rpc-amoy.polygon.technology

# Optional: Polygon Amoy specific RPC override (used by Amoy chain entry when
# VITE_RPC_URL is not set)
# VITE_RPC_URL_AMOY=https://rpc-amoy.polygon.technology

# Polymarket testnet USDC on Amoy (required for Polymarket-pegged side bets)
# VITE_AMOY_USDC=0x...

# Polymarket Conditional Tokens Framework address on Amoy (required for
# settle-by-referenced-lookup against Polymarket markets)
# VITE_AMOY_POLYMARKET_CTF=0x...

# Contract Addresses (update after deployment)
# VITE_CONTRACT_ADDRESS=0x1234567890123456789012345678901234567890

# IPFS / Pinata Configuration
# Pinata is used for uploading and pinning content to IPFS
# Get your credentials at https://app.pinata.cloud/developers/api-keys

# Pinata JWT Token (recommended - get from Pinata dashboard)
# This is required for uploading metadata to IPFS
VITE_PINATA_JWT=your_pinata_jwt_token_here

# Pinata API Key and Secret (alternative to JWT)
# VITE_PINATA_API_KEY=your_pinata_api_key
# VITE_PINATA_API_SECRET=your_pinata_api_secret

# Pinata Gateway URL (optional - for dedicated gateway)
# Default uses Pinata's public gateway
# VITE_PINATA_GATEWAY=https://your-gateway.mypinata.cloud

# IPFS Gateway URL for retrieving token and market data
# Default: Uses Pinata gateway
VITE_IPFS_GATEWAY=https://gateway.pinata.cloud

# MATIC/USD price fallback (used if CoinGecko API fails)
# VITE_MATIC_USD_FALLBACK=0.5

# WalletConnect Configuration (Optional)
# WalletConnect is always available with a fallback project ID
# For production deployments, get your own project ID from https://cloud.walletconnect.com
# VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# ThirdWeb Configuration (Optional)
# ThirdWeb provides enhanced wallet connection UX
# For production deployments, get your own client ID from https://thirdweb.com/dashboard
# VITE_THIRDWEB_CLIENT_ID=your_client_id_here

# Application URL (Required for production)
# Used for WalletConnect metadata and other external integrations
# For local development: http://localhost:5173
# For production: https://your-domain.com
VITE_APP_URL=http://localhost:5173
