{
  "name": "prediction-dao-research",
  "version": "1.0.0",
  "description": "Futarchy Prediction DAO with privacy-preserving mechanisms",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:unit": "hardhat test test/*.test.js",
    "test:integration": "hardhat test test/integration/**/*.test.js",
    "test:integration:clearpath": "hardhat test test/integration/clearpath/**/*.test.js",
    "test:integration:oracle": "hardhat test test/integration/oracle/*.test.js",
    "test:integration:fairwins": "hardhat test test/integration/fairwins/**/*.test.js",
    "test:oracles": "hardhat test test/oracles/*.test.js",
    "test:fork": "hardhat test test/fork/*.test.js",
    "test:all": "hardhat test test/**/*.test.js",
    "test:gas": "REPORT_GAS=true hardhat test",
    "test:coverage": "COVERAGE=true TZ=UTC hardhat coverage --testfiles '{test/*.test.js,test/access/**/*.test.js,test/account/**/*.test.js,test/clearpath/**/*.test.js,test/custody/**/*.test.js,test/intent/**/*.test.js,test/oracles/**/*.test.js,test/pools/**/*.test.js,test/tokens/**/*.test.js,test/upgradeable/**/*.test.js,test/integration/**/*.test.js}'",
    "deploy:local": "hardhat run scripts/deploy/deploy.js --network localhost",
    "deploy:mordor": "hardhat run scripts/deploy/deploy.js --network mordor",
    "deploy:deterministic": "hardhat run scripts/deploy/deploy-deterministic.js",
    "deploy:amoy": "hardhat run scripts/deploy/01-deploy-core.js --network amoy && hardhat run scripts/deploy/02-deploy-rbac.js --network amoy && hardhat run scripts/deploy/03-deploy-markets.js --network amoy && hardhat run scripts/deploy/04-deploy-registries.js --network amoy && hardhat run scripts/deploy/05-configure.js --network amoy && hardhat run scripts/deploy/06-verify.js --network amoy",
    "deploy:polygon": "hardhat run scripts/deploy/deploy.js --network polygon",
    "deploy:etc": "hardhat run scripts/deploy/deploy.js --network etc",
    "verify:mordor": "hardhat run scripts/deploy/verify.js --network mordor",
    "verify:etc": "hardhat run scripts/deploy/verify.js --network etc",
    "verify:amoy": "hardhat run scripts/deploy/verify.js --network amoy",
    "verify:polygon": "hardhat run scripts/deploy/verify.js --network polygon",
    "check:storage-layout": "hardhat run scripts/deploy/check-storage-layout.js",
    "sync:frontend-contracts": "node scripts/utils/sync-frontend-contracts.js --network mordor --chainId 63",
    "sync:frontend-contracts:amoy": "node scripts/utils/sync-frontend-contracts.js --network amoy --chainId 80002",
    "sync:frontend-contracts:polygon": "node scripts/utils/sync-frontend-contracts.js --network polygon --chainId 137",
    "migrate:memberships:polygon": "hardhat run scripts/operations/migrate-memberships-007.js --network polygon",
    "lockdown:polygon": "hardhat run scripts/operations/prelaunch-lockdown-007.js --network polygon",
    "sync:frontend-contracts:local": "node scripts/utils/sync-frontend-contracts.js --network localhost --chainId 1337",
    "test:frontend": "npm --prefix frontend run test:run",
    "lock:sync": "npm install --package-lock-only && npm --prefix frontend install --package-lock-only",
    "seed:testnet": "hardhat run scripts/operations/seed-testnet.js --network mordor",
    "seed:local": "hardhat run scripts/operations/seed-local.js --network localhost",
    "setup:local": "npm run deploy:local && npm run sync:frontend-contracts:local && npm run seed:local",
    "node": "hardhat node",
    "clean": "hardhat clean",
    "frontend": "cd frontend && npm run dev",
    "floppy:mount": "bash ./scripts/operations/floppy-key/mount.sh",
    "floppy:unmount": "bash ./scripts/operations/floppy-key/unmount.sh",
    "floppy:create": "node ./scripts/operations/floppy-key/index.js create",
    "floppy:test": "node ./scripts/operations/floppy-key/index.js test",
    "floppy:info": "node ./scripts/operations/floppy-key/index.js info",
    "floppy:store-admin": "node ./scripts/operations/floppy-key/store-admin-key.js",
    "purchase:friend-market": "npx hardhat run ./scripts/operations/purchase-friend-market-membership.js --network mordor",
    "create:friend-bet": "npx hardhat run ./scripts/operations/create-friend-market-bet.js --network mordor"
  },
  "keywords": [
    "futarchy",
    "prediction-markets",
    "dao",
    "governance",
    "privacy",
    "zero-knowledge",
    "maci",
    "nightmarket",
    "gnosis"
  ],
  "author": "",
  "license": "Apache-2.0",
  "devDependencies": {
    "@chainlink/contracts": "^1.3.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@openzeppelin/contracts": "5.4.0",
    "@openzeppelin/contracts-upgradeable": "5.4.0",
    "@openzeppelin/hardhat-upgrades": "^3.9.0",
    "@pinata/sdk": "^2.1.0",
    "@safe-global/safe-singleton-factory": "^2.0.0",
    "@semaphore-protocol/group": "^4.14.2",
    "@semaphore-protocol/identity": "^4.14.2",
    "@semaphore-protocol/proof": "^4.14.2",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@uma/core": "^2.61.0",
    "chai": "^4.5.0",
    "dotenv": "^17.2.4",
    "ethereum-cryptography": "^2.2.1",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.2",
    "hardhat-gas-reporter": "^2.3.0",
    "solc": "0.8.24",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@semaphore-protocol/contracts": "^4.14.2"
  }
}
